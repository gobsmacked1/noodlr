{{! Noodlr main configuration window. Grouped BY FEATURE: each block lays out
    Provider -> Model -> (custom URL) -> API key, with plain-language help. }}

{{#*inline "help"}}
  <ul class="noodlr-help">
    <li><strong>{{localize "NOODLR.Help.What"}}</strong> {{what}}</li>
    <li><strong>{{localize "NOODLR.Help.Requires"}}</strong> {{requires}}</li>
    <li><strong>{{localize "NOODLR.Help.Without"}}</strong> {{without}}</li>
  </ul>
{{/inline}}

{{#*inline "providerBlock"}}
  <div class="noodlr-field">
    <label>{{localize "NOODLR.Provider.Provider.Name"}}</label>
    <p class="notes">{{localize "NOODLR.Provider.Provider.Hint"}}</p>
    <select name="{{id}}.provider" data-role="provider">
      <option value="openrouter" {{#if isOpenrouter}}selected{{/if}}>OpenRouter</option>
      <option value="custom" {{#if isCustom}}selected{{/if}}>{{localize "NOODLR.Provider.Custom"}}</option>
    </select>
  </div>

  <div class="noodlr-field">
    <label>{{localize "NOODLR.Provider.Model.Name"}}</label>
    <p class="notes">{{localize "NOODLR.Provider.Model.Hint"}}</p>
    <input
      type="text"
      name="{{id}}.model"
      data-role="model"
      value="{{model}}"
      {{#if isOpenrouter}}list="noodlr-or-models"{{/if}}
      autocomplete="off"
    />
  </div>

  <div class="noodlr-field noodlr-custom-only">
    <label>{{localize "NOODLR.Provider.BaseUrl.Name"}}</label>
    <p class="notes">{{localize "NOODLR.Provider.BaseUrl.Hint"}}</p>
    <input type="text" name="{{id}}.baseUrl" value="{{baseUrl}}" placeholder="http://127.0.0.1:11434/v1" autocomplete="off" />
  </div>

  <div class="noodlr-field">
    <label>{{localize "NOODLR.Provider.ApiKey.Name"}}</label>
    <p class="notes">{{localize "NOODLR.Provider.ApiKey.Hint"}}</p>
    <input
      type="password"
      name="{{id}}.apiKey"
      value=""
      autocomplete="off"
      placeholder="{{#if hasKey}}{{localize 'NOODLR.Provider.ApiKey.Saved'}}{{else}}{{localize 'NOODLR.Provider.ApiKey.None'}}{{/if}}"
    />
    {{#if hasKey}}
      <label class="noodlr-inline"><input type="checkbox" name="{{id}}.apiKeyClear" /> {{localize "NOODLR.Provider.ApiKey.Clear"}}</label>
    {{/if}}
  </div>
{{/inline}}

<section class="noodlr-settings">
  <header class="noodlr-settings__header">
    <i class="fa-solid fa-dragon"></i>
    <h2>{{moduleTitle}} — {{localize "NOODLR.Settings.Title"}}</h2>
    <span class="noodlr-settings__version">v{{version}}</span>
  </header>

  <p class="noodlr-settings__intro">{{localize "NOODLR.Settings.Intro"}}</p>

  <datalist id="noodlr-or-models"></datalist>

  {{! ---- Dungeon Master Chat ---- }}
  <fieldset class="noodlr-settings__section" data-feature="chat">
    <legend><i class="fa-solid fa-comments"></i> {{chat.title}}</legend>
    {{> help chat}}
    {{> providerBlock chat}}

    <div class="noodlr-settings__actions">
      <button type="button" data-action="testConnection">
        <i class="fa-solid fa-plug"></i> {{localize "NOODLR.Settings.TestConnection"}}
      </button>
    </div>

    <label class="noodlr-inline">
      <input type="checkbox" name="chat.continueAfterRoll" {{#if continueAfterRoll}}checked{{/if}} />
      {{localize "NOODLR.Settings.ChatContinueAfterRoll.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Settings.ChatContinueAfterRoll.Hint"}}</p>

    <label class="noodlr-settings__label">{{localize "NOODLR.Settings.ChatPromptLegend"}}</label>
    <p class="notes">
      {{localize "NOODLR.Settings.ChatPromptHint"}}
      {{#if usingDefault}}<em>({{localize "NOODLR.Settings.UsingDefault"}})</em>{{/if}}
    </p>
    <textarea name="systemPrompt" class="noodlr-settings__prompt" rows="14" maxlength="{{maxLength}}" spellcheck="true">{{systemPrompt}}</textarea>
    <div class="noodlr-settings__actions">
      <button type="button" data-action="resetPrompt">
        <i class="fa-solid fa-rotate-left"></i> {{localize "NOODLR.Settings.ResetPrompt"}}
      </button>
    </div>
  </fieldset>

  {{! ---- Voice (TTS) ---- }}
  <fieldset class="noodlr-settings__section" data-feature="tts">
    <legend><i class="fa-solid fa-volume-high"></i> {{tts.title}}</legend>
    {{> help tts}}

    <label class="noodlr-inline">
      <input type="checkbox" name="tts.enabled" {{#if ttsEnabled}}checked{{/if}} />
      {{localize "NOODLR.Media.TtsEnabled.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.TtsEnabled.Hint"}}</p>

    {{> providerBlock tts}}

    <div class="noodlr-field">
      <label>{{localize "NOODLR.Media.TtsVoice.Name"}}</label>
      <p class="notes">{{localize "NOODLR.Media.TtsVoice.Hint"}}</p>
      <input type="text" name="tts.voice" value="{{ttsVoice}}" autocomplete="off" />
    </div>

    <label class="noodlr-inline">
      <input type="checkbox" name="tts.autoRead" {{#if ttsAutoRead}}checked{{/if}} />
      {{localize "NOODLR.Media.TtsAutoRead.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.TtsAutoRead.Hint"}}</p>

    {{! Inline self-test: synthesize a short phrase and report result/error right here. The
        input uses data-role (not name) so the test text is never persisted with the form. }}
    <div class="noodlr-field">
      <label>{{localize "NOODLR.Media.TtsTest.Name"}}</label>
      <p class="notes">{{localize "NOODLR.Media.TtsTest.Hint"}}</p>
      <div class="noodlr-inline-controls">
        <input type="text" data-role="tts-test-input" maxlength="140"
          placeholder="{{localize 'NOODLR.Media.TtsTest.Placeholder'}}" autocomplete="off" />
        <button type="button" data-action="testTts">
          <i class="fa-solid fa-volume-high"></i> {{localize "NOODLR.Media.TtsTest.Button"}}
        </button>
      </div>
      <p class="noodlr-test-status" data-role="tts-test-status" aria-live="polite"></p>
    </div>

    <label class="noodlr-inline">
      <input type="checkbox" name="tts.pitchSupported" {{#if ttsPitchSupported}}checked{{/if}} />
      {{localize "NOODLR.Media.TtsPitch.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.TtsPitch.Hint"}}</p>

    {{! Per-creature-type voice + pitch lives in its own pop-out (30+ rows). }}
    <div class="noodlr-field">
      <label>{{localize "NOODLR.Media.CreatureVoices.Name"}}</label>
      <p class="notes">{{localize "NOODLR.Media.CreatureVoices.Hint"}}</p>
      <button type="button" data-action="openCreatureVoices">
        <i class="fa-solid fa-masks-theater"></i> {{localize "NOODLR.Media.CreatureVoices.Open"}}
      </button>
    </div>
  </fieldset>

  {{! ---- Scene Art (Image) ---- }}
  <fieldset class="noodlr-settings__section" data-feature="image">
    <legend><i class="fa-solid fa-image"></i> {{image.title}}</legend>
    {{> help image}}
    {{> providerBlock image}}

    <div class="noodlr-field">
      <label>{{localize "NOODLR.Media.ImagePositive.Name"}}</label>
      <p class="notes">{{localize "NOODLR.Media.ImagePositive.Hint"}}</p>
      <textarea name="image.positive" class="noodlr-settings__block" rows="2" spellcheck="true">{{imagePositive}}</textarea>
    </div>

    <div class="noodlr-field">
      <label>{{localize "NOODLR.Media.ImageNegative.Name"}}</label>
      <p class="notes">{{localize "NOODLR.Media.ImageNegative.Hint"}}</p>
      <textarea name="image.negative" class="noodlr-settings__block" rows="2" spellcheck="true">{{imageNegative}}</textarea>
    </div>

    <label class="noodlr-inline">
      <input type="checkbox" name="image.expand" {{#if imageExpand}}checked{{/if}} />
      {{localize "NOODLR.Media.ImageExpand.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.ImageExpand.Hint"}}</p>

    <div class="noodlr-grid">
      <div class="noodlr-field">
        <label>{{localize "NOODLR.Media.ImageSize.Name"}}</label>
        <input type="text" name="image.size" value="{{imageSize}}" />
      </div>
      <div class="noodlr-field">
        <label>{{localize "NOODLR.Media.ImageSteps.Name"}}</label>
        <input type="number" name="image.steps" value="{{imageSteps}}" min="1" max="150" step="1" />
      </div>
      <div class="noodlr-field">
        <label>{{localize "NOODLR.Media.ImageCfg.Name"}}</label>
        <input type="number" name="image.cfg" value="{{imageCfg}}" min="0" max="30" step="0.5" />
      </div>
      <div class="noodlr-field">
        <label>{{localize "NOODLR.Media.ImageSampler.Name"}}</label>
        <input type="text" name="image.sampler" value="{{imageSampler}}" />
      </div>
      <div class="noodlr-field">
        <label>{{localize "NOODLR.Media.ImageSeed.Name"}}</label>
        <input type="number" name="image.seed" value="{{imageSeed}}" step="1" />
      </div>
    </div>
    <p class="notes">{{localize "NOODLR.Media.ImageParamsNote"}}</p>

    {{! ---- Delivery, storage & triggers ---- }}
    <div class="noodlr-field">
      <label>{{localize "NOODLR.Media.ImageFolder.Name"}}</label>
      <p class="notes">{{localize "NOODLR.Media.ImageFolder.Hint"}}</p>
      <div class="noodlr-inline-controls">
        <input type="text" name="image.mediaFolder" value="{{imageMediaFolder}}" placeholder="assets/noodlr-out" autocomplete="off" />
        <button type="button" data-action="browseMediaFolder"><i class="fa-solid fa-folder-open"></i> {{localize "NOODLR.Media.ImageFolder.Browse"}}</button>
      </div>
    </div>

    <label class="noodlr-inline">
      <input type="checkbox" name="image.persist" {{#if imagePersist}}checked{{/if}} />
      {{localize "NOODLR.Media.ImagePersist.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.ImagePersist.Hint"}}</p>

    <label class="noodlr-inline">
      <input type="checkbox" name="image.chatTrigger" {{#if imageChatTrigger}}checked{{/if}} />
      {{localize "NOODLR.Media.ImageChatTrigger.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.ImageChatTrigger.Hint"}}</p>

    <label class="noodlr-inline">
      <input type="checkbox" name="image.allowPlayers" {{#if imageAllowPlayers}}checked{{/if}} />
      {{localize "NOODLR.Media.ImageAllowPlayers.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.ImageAllowPlayers.Hint"}}</p>
  </fieldset>

  {{! ---- Voice Transcription (push-to-log) ---- }}
  <fieldset class="noodlr-settings__section" data-feature="transcription">
    <legend><i class="fa-solid fa-microphone-lines"></i> {{transcription.title}}</legend>
    {{> help transcription}}

    <label class="noodlr-inline">
      <input type="checkbox" name="transcription.enabled" {{#if transcriptEnabled}}checked{{/if}} />
      {{localize "NOODLR.Media.TranscriptionEnabled.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.TranscriptionEnabled.Hint"}}</p>

    {{> providerBlock transcription}}

    <label class="noodlr-inline">
      <input type="checkbox" name="transcription.postChat" {{#if transcriptPostChat}}checked{{/if}} />
      {{localize "NOODLR.Media.PushPostChat.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.PushPostChat.Hint"}}</p>

    <div class="noodlr-field">
      <label>{{localize "NOODLR.Media.PushSegment.Name"}}</label>
      <p class="notes">{{localize "NOODLR.Media.PushSegment.Hint"}}</p>
      <input type="number" name="transcription.segment" value="{{transcriptSegment}}" min="5" max="60" step="5" />
    </div>
    <p class="notes">{{localize "NOODLR.Media.PushIngestElsewhere"}}</p>
  </fieldset>

  {{! ---- Music (text-to-audio) ---- }}
  <fieldset class="noodlr-settings__section" data-feature="music">
    <legend><i class="fa-solid fa-music"></i> {{music.title}}</legend>
    {{> help music}}

    <label class="noodlr-inline">
      <input type="checkbox" name="music.enabled" {{#if musicEnabled}}checked{{/if}} />
      {{localize "NOODLR.Media.MusicEnabled.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.MusicEnabled.Hint"}}</p>

    {{> providerBlock music}}

    <div class="noodlr-field">
      <label>{{localize "NOODLR.Media.MusicPlaylist.Name"}}</label>
      <p class="notes">{{localize "NOODLR.Media.MusicPlaylist.Hint"}}</p>
      <input type="text" name="music.playlist" value="{{musicPlaylist}}" autocomplete="off" />
    </div>

    <div class="noodlr-grid">
      <div class="noodlr-field">
        <label>{{localize "NOODLR.Media.MusicMin.Name"}}</label>
        <input type="number" name="music.minSec" value="{{musicMinSec}}" min="1" max="600" step="1" />
      </div>
      <div class="noodlr-field">
        <label>{{localize "NOODLR.Media.MusicMax.Name"}}</label>
        <input type="number" name="music.maxSec" value="{{musicMaxSec}}" min="1" max="600" step="1" />
      </div>
    </div>
    <p class="notes">{{localize "NOODLR.Media.MusicDurationNote"}}</p>

    <label class="noodlr-inline">
      <input type="checkbox" name="music.chatTrigger" {{#if musicChatTrigger}}checked{{/if}} />
      {{localize "NOODLR.Media.MusicTrigger.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.MusicTrigger.Hint"}}</p>

    <label class="noodlr-inline">
      <input type="checkbox" name="music.allowPlayers" {{#if musicAllowPlayers}}checked{{/if}} />
      {{localize "NOODLR.Media.MediaAllowPlayers.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.MediaAllowPlayers.Hint"}}</p>
  </fieldset>

  {{! ---- Video (text-to-video, experimental) ---- }}
  <fieldset class="noodlr-settings__section" data-feature="video">
    <legend><i class="fa-solid fa-film"></i> {{video.title}}</legend>
    {{> help video}}

    <label class="noodlr-inline">
      <input type="checkbox" name="video.enabled" {{#if videoEnabled}}checked{{/if}} />
      {{localize "NOODLR.Media.VideoEnabled.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.VideoEnabled.Hint"}}</p>

    {{> providerBlock video}}

    <div class="noodlr-grid">
      <div class="noodlr-field">
        <label>{{localize "NOODLR.Media.VideoDuration.Name"}}</label>
        <input type="number" name="video.duration" value="{{videoDuration}}" min="6" max="30" step="1" />
      </div>
      <div class="noodlr-field">
        <label>{{localize "NOODLR.Media.VideoResolution.Name"}}</label>
        <input type="text" name="video.resolution" value="{{videoResolution}}" placeholder="720p" />
      </div>
      <div class="noodlr-field">
        <label>{{localize "NOODLR.Media.VideoAspect.Name"}}</label>
        <input type="text" name="video.aspect" value="{{videoAspect}}" placeholder="16:9" />
      </div>
    </div>
    <p class="notes">{{localize "NOODLR.Media.VideoDurationNote"}}</p>

    <label class="noodlr-inline">
      <input type="checkbox" name="video.chatTrigger" {{#if videoChatTrigger}}checked{{/if}} />
      {{localize "NOODLR.Media.VideoTrigger.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.VideoTrigger.Hint"}}</p>

    <label class="noodlr-inline">
      <input type="checkbox" name="video.allowPlayers" {{#if videoAllowPlayers}}checked{{/if}} />
      {{localize "NOODLR.Media.MediaAllowPlayers.Name"}}
    </label>
    <p class="notes">{{localize "NOODLR.Media.MediaAllowPlayers.Hint"}}</p>
  </fieldset>

  {{! ---- Context & injections ---- }}
  <fieldset class="noodlr-settings__section">
    <legend><i class="fa-solid fa-layer-group"></i> {{localize "NOODLR.Settings.ContextLegend"}}</legend>

    <label class="noodlr-settings__label">{{localize "NOODLR.Prompt.AuthorNote.Name"}}</label>
    <p class="notes">{{localize "NOODLR.Prompt.AuthorNote.Hint"}}</p>
    <textarea name="authorNote" class="noodlr-settings__block" rows="3" spellcheck="true">{{authorNote}}</textarea>

    <label class="noodlr-settings__label">{{localize "NOODLR.Prompt.PostHistory.Name"}}</label>
    <p class="notes">{{localize "NOODLR.Prompt.PostHistory.Hint"}}</p>
    <textarea name="postHistory" class="noodlr-settings__block" rows="3" spellcheck="true">{{postHistory}}</textarea>

    <label class="noodlr-settings__label">{{localize "NOODLR.Prompt.CombatReminder.Name"}}</label>
    <p class="notes">{{localize "NOODLR.Prompt.CombatReminder.Hint"}}</p>
    <textarea name="combatReminder" class="noodlr-settings__block" rows="3" spellcheck="true">{{combatReminder}}</textarea>

    <label class="noodlr-settings__label">{{localize "NOODLR.Combat.PromptName"}}</label>
    <p class="notes">{{localize "NOODLR.Combat.PromptHint"}}</p>
    <textarea name="combatPrompt" class="noodlr-settings__block" rows="5" spellcheck="true">{{combatPrompt}}</textarea>
  </fieldset>

  <div class="noodlr-settings__actions">
    <button type="submit">
      <i class="fa-solid fa-floppy-disk"></i> {{localize "NOODLR.Settings.Save"}}
    </button>
  </div>
</section>

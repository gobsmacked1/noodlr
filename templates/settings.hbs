{{! Noodlr settings window (form). Chat system-prompt editor + provider test. }}
<section class="noodlr-settings">
  <header class="noodlr-settings__header">
    <i class="fa-solid fa-dragon"></i>
    <h2>{{moduleTitle}} — {{localize "NOODLR.Settings.Title"}}</h2>
    <span class="noodlr-settings__version">v{{version}}</span>
  </header>

  <p class="noodlr-settings__intro">{{localize "NOODLR.Settings.Intro"}}</p>

  <fieldset class="noodlr-settings__section">
    <legend>{{localize "NOODLR.Settings.ChatPromptLegend"}}</legend>
    <p class="notes">
      {{localize "NOODLR.Settings.ChatPromptHint"}}
      {{#if usingDefault}}<em>({{localize "NOODLR.Settings.UsingDefault"}})</em>{{/if}}
    </p>
    <textarea
      name="systemPrompt"
      class="noodlr-settings__prompt"
      rows="18"
      maxlength="{{maxLength}}"
      spellcheck="true"
    >{{systemPrompt}}</textarea>
    <div class="noodlr-settings__actions">
      <button type="button" data-action="resetPrompt">
        <i class="fa-solid fa-rotate-left"></i> {{localize "NOODLR.Settings.ResetPrompt"}}
      </button>
      <button type="button" data-action="testConnection">
        <i class="fa-solid fa-plug"></i> {{localize "NOODLR.Settings.TestConnection"}}
      </button>
    </div>
  </fieldset>

  <fieldset class="noodlr-settings__section">
    <legend>{{localize "NOODLR.Settings.ContextLegend"}}</legend>

    <label class="noodlr-settings__label">{{localize "NOODLR.Prompt.AuthorNote.Name"}}</label>
    <p class="notes">{{localize "NOODLR.Prompt.AuthorNote.Hint"}}</p>
    <textarea name="authorNote" class="noodlr-settings__block" rows="3" spellcheck="true">{{authorNote}}</textarea>

    <label class="noodlr-settings__label">{{localize "NOODLR.Prompt.PostHistory.Name"}}</label>
    <p class="notes">{{localize "NOODLR.Prompt.PostHistory.Hint"}}</p>
    <textarea name="postHistory" class="noodlr-settings__block" rows="3" spellcheck="true">{{postHistory}}</textarea>

    <label class="noodlr-settings__label">{{localize "NOODLR.Prompt.CombatReminder.Name"}}</label>
    <p class="notes">{{localize "NOODLR.Prompt.CombatReminder.Hint"}}</p>
    <textarea name="combatReminder" class="noodlr-settings__block" rows="3" spellcheck="true">{{combatReminder}}</textarea>

    <label class="noodlr-settings__label">{{localize "NOODLR.Combat.PromptName"}}</label>
    <p class="notes">{{localize "NOODLR.Combat.PromptHint"}}</p>
    <textarea name="combatPrompt" class="noodlr-settings__block" rows="5" spellcheck="true">{{combatPrompt}}</textarea>
  </fieldset>

  <div class="noodlr-settings__actions">
    <button type="submit">
      <i class="fa-solid fa-floppy-disk"></i> {{localize "NOODLR.Settings.Save"}}
    </button>
  </div>

  <p class="noodlr-settings__note">{{localize "NOODLR.Settings.PhaseNote"}}</p>
</section>

{{! Noodlr chat panel. Static shell; bubbles are added imperatively (see chat-panel.ts). }}
<section class="noodlr-chat">
  {{#unless configured}}
    <div class="noodlr-chat__banner">
      <i class="fa-solid fa-triangle-exclamation"></i>
      {{localize "NOODLR.ChatPanel.NotConfigured"}}
    </div>
  {{/unless}}

  <div class="noodlr-chat__log" data-role="log"></div>

  <footer class="noodlr-chat__composer">
    <textarea
      data-role="input"
      rows="2"
      placeholder="{{localize "NOODLR.ChatPanel.InputPlaceholder"}}"
      disabled
    ></textarea>
    <button type="button" data-role="send" title="{{localize "NOODLR.ChatPanel.Send"}}" disabled>
      <i class="fa-solid fa-paper-plane"></i>
    </button>
  </footer>

  <p class="noodlr-chat__version">v{{version}}</p>
</section>
